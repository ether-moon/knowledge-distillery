#!/usr/bin/env bash
# scripts/knowledge-gate — Knowledge Vault interface
set -euo pipefail

resolve_vault_path() {
  if [ -n "${KNOWLEDGE_VAULT_PATH:-}" ]; then
    echo "${KNOWLEDGE_VAULT_PATH}"
    return
  fi

  local repo_root
  repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
  if [ -n "$repo_root" ]; then
    echo "${repo_root}/.knowledge/vault.db"
    return
  fi

  local dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -f "${dir}/.knowledge/vault.db" ]; then
      echo "${dir}/.knowledge/vault.db"
      return
    fi
    dir="$(dirname "$dir")"
  done

  echo "${PWD}/.knowledge/vault.db"
}

# Resolve plugin root for bundled assets
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SCHEMA_PATH="${PLUGIN_ROOT}/schema/vault.sql"

VAULT="$(resolve_vault_path)"
CMD="${1:-help}"
shift || true

case "$CMD" in
  help|--help|-h|init-db) ;;
  *)
    if [ ! -f "$VAULT" ]; then
      echo "Knowledge vault not found at $VAULT" >&2
      exit 1
    fi
    ;;
esac

# Common utility: single-quote escaping
esc() { echo "${1//\'/\'\'}"; }

# JSON query wrapper: sqlite3 -json returns empty string on 0 rows; this returns []
sql_json() { local result; result=$(sqlite3 -json "$VAULT" "$1"); echo "${result:-[]}"; }

RESERVED_ENTRY_IDS=""

id_reserved() {
  printf '%s' "$RESERVED_ENTRY_IDS" | grep -Fxq -- "$1"
}

reserve_id() {
  RESERVED_ENTRY_IDS="${RESERVED_ENTRY_IDS}$1"$'\n'
}

make_unique_entry_id() {
  local base_id="$1"
  local candidate="$base_id"
  local suffix=2

  while sqlite3 "$VAULT" "SELECT 1 FROM entries WHERE id='$(esc "$candidate")' LIMIT 1;" | grep -q 1 || id_reserved "$candidate"; do
    candidate="${base_id}-${suffix}"
    suffix=$((suffix + 1))
  done

  echo "$candidate"
}

list_migration_files() {
  local migration_dir="$1"
  find "$migration_dir" -maxdepth 1 -type f -name '*.sql' -print 2>/dev/null \
    | while IFS= read -r f; do
        local version
        version=$(basename "$f" .sql | grep -oE '^[0-9]+')
        [ -n "$version" ] || continue
        printf '%010d|%s\n' "$((10#$version))" "$f"
      done \
    | sort \
    | cut -d'|' -f2-
}

init_db() {
  local target="${1:-$VAULT}"

  if [ -e "$target" ]; then
    echo "ERROR: Knowledge vault already exists at $target" >&2
    return 1
  fi
  if [ ! -f "$SCHEMA_PATH" ]; then
    echo "ERROR: Bundled schema not found at $SCHEMA_PATH" >&2
    return 1
  fi

  mkdir -p "$(dirname "$target")"
  sqlite3 "$target" < "$SCHEMA_PATH"
  echo "Initialized knowledge vault at $target"
}

# ============================================================
# 1. Knowledge Query Commands (Agent Runtime)
# ============================================================

query_by_path() {
  local filepath ids_only
  filepath="$(esc "$1")"
  ids_only="${2:-false}"

  if [ "$ids_only" = "true" ]; then
    sqlite3 "$VAULT" "
      PRAGMA foreign_keys = ON;
      WITH RECURSIVE prefixes(p, rest) AS (
        SELECT '', '${filepath}' || '/'
        UNION ALL
        SELECT p || substr(rest, 1, instr(rest, '/')),
               substr(rest, instr(rest, '/') + 1)
        FROM prefixes WHERE rest <> '' AND instr(rest, '/') > 0
      ), filepath_prefixes AS (
        SELECT p AS prefix FROM prefixes WHERE p <> ''
      ), matched_domains AS (
        SELECT dp.domain FROM domain_paths dp
        JOIN filepath_prefixes fp ON fp.prefix = dp.pattern
        UNION
        SELECT dp.domain FROM domain_paths dp WHERE dp.pattern = '*'
      )
      SELECT COALESCE(json_group_array(id), '[]')
      FROM (
        SELECT DISTINCT e.id
        FROM entries e
        JOIN entry_domains ed ON ed.entry_id = e.id
        WHERE e.status = 'active'
          AND ed.domain IN (SELECT domain FROM matched_domains)
        ORDER BY e.title
      );
    "
    return
  fi

  sql_json "
    PRAGMA foreign_keys = ON;
    WITH RECURSIVE prefixes(p, rest) AS (
      SELECT '', '${filepath}' || '/'
      UNION ALL
      SELECT p || substr(rest, 1, instr(rest, '/')),
             substr(rest, instr(rest, '/') + 1)
      FROM prefixes WHERE rest <> '' AND instr(rest, '/') > 0
    ), filepath_prefixes AS (
      SELECT p AS prefix FROM prefixes WHERE p <> ''
    ), matched_domains AS (
      SELECT dp.domain FROM domain_paths dp
      JOIN filepath_prefixes fp ON fp.prefix = dp.pattern
      UNION
      SELECT dp.domain FROM domain_paths dp WHERE dp.pattern = '*'
    )
    SELECT DISTINCT e.id, e.type, e.title, e.claim
    FROM entries e
    JOIN entry_domains ed ON ed.entry_id = e.id
    WHERE e.status = 'active'
      AND ed.domain IN (SELECT domain FROM matched_domains)
    ORDER BY e.title;
  "
}

query_by_domain() {
  local domain ids_only
  domain="$(esc "$1")"
  ids_only="${2:-false}"

  if [ "$ids_only" = "true" ]; then
    sqlite3 "$VAULT" "
      PRAGMA foreign_keys = ON;
      SELECT COALESCE(json_group_array(id), '[]')
      FROM (
        SELECT DISTINCT e.id
        FROM entries e
        JOIN entry_domains ed ON ed.entry_id = e.id
        WHERE e.status = 'active'
          AND ed.domain = '${domain}'
        ORDER BY e.title
      );
    "
    return
  fi

  sql_json "
    PRAGMA foreign_keys = ON;
    SELECT DISTINCT e.id, e.type, e.title, e.claim
    FROM entries e
    JOIN entry_domains ed ON ed.entry_id = e.id
    WHERE e.status = 'active'
      AND ed.domain = '${domain}'
    ORDER BY e.title;
  "
}

search_entries() {
  local keyword ids_only
  keyword="$(esc "${1//\"/\"\"}")"
  ids_only="${2:-false}"

  if [ "$ids_only" = "true" ]; then
    sqlite3 "$VAULT" "
      SELECT COALESCE(json_group_array(id), '[]')
      FROM (
        SELECT e.id
        FROM entries_fts fts
        JOIN entries e ON e.rowid = fts.rowid
        WHERE entries_fts MATCH '\"${keyword}\"'
          AND e.status = 'active'
        ORDER BY fts.rank
      );
    "
    return
  fi

  sql_json "
    SELECT e.id, e.type, e.title, e.claim
    FROM entries_fts fts
    JOIN entries e ON e.rowid = fts.rowid
    WHERE entries_fts MATCH '\"${keyword}\"'
      AND e.status = 'active'
    ORDER BY fts.rank;
  "
}

get_entries() {
  local item_ids=("$@")

  [ "${#item_ids[@]}" -gt 0 ] || { echo "[]"; return; }

  local requested_values="" item_id index requested_sql
  for index in "${!item_ids[@]}"; do
    item_id="$(esc "${item_ids[$index]}")"
    if [ -n "$requested_values" ]; then
      requested_values="${requested_values}, "
    fi
    requested_values="${requested_values}('${item_id}', $((index + 1)))"
  done

  requested_sql="WITH requested(id, position) AS (VALUES ${requested_values})"

  # Fail fast if any requested ID is missing from the vault
  local missing
  missing=$(sqlite3 "$VAULT" "
    ${requested_sql}
    SELECT GROUP_CONCAT(r.id, ', ')
    FROM requested r
    LEFT JOIN entries e ON e.id = r.id
    WHERE e.id IS NULL;
  ")
  if [ -n "$missing" ]; then
    echo "ERROR: entry IDs not found: ${missing}" >&2
    return 1
  fi

  # If jq is available, return enriched JSON with domains and evidence
  if command -v jq &>/dev/null; then
    local entries domains evidence
    entries=$(sql_json "
      ${requested_sql}
      SELECT e.*, r.position
      FROM requested r
      JOIN entries e ON e.id = r.id
      ORDER BY r.position;
    ")
    domains=$(sql_json "
      ${requested_sql}
      SELECT ed.entry_id, ed.domain, r.position
      FROM requested r
      JOIN entry_domains ed ON ed.entry_id = r.id
      ORDER BY r.position, ed.domain;
    ")
    evidence=$(sql_json "
      ${requested_sql}
      SELECT ev.entry_id, ev.type, ev.ref, r.position
      FROM requested r
      JOIN evidence ev ON ev.entry_id = r.id
      ORDER BY r.position, ev.type, ev.ref;
    ")

    jq -n --argjson entries "$entries" --argjson domains "$domains" --argjson evidence "$evidence" '
      $entries
      | map(
          . as $entry
          | ($entry + {
              domains: ($domains | map(select(.entry_id == $entry.id) | .domain)),
              evidence: ($evidence | map(select(.entry_id == $entry.id) | {type, ref}))
            } | del(.position))
        )
    '
  else
    sql_json "
      ${requested_sql}
      SELECT e.*
      FROM requested r
      JOIN entries e ON e.id = r.id
      ORDER BY r.position;
    "
  fi
}

get_entry() {
  get_entries "$1"
}

list_entries() {
  local ids_only="${1:-false}"

  if [ "$ids_only" = "true" ]; then
    sqlite3 "$VAULT" "
      SELECT COALESCE(json_group_array(id), '[]')
      FROM (
        SELECT id
        FROM entries
        WHERE status = 'active'
        ORDER BY title
      );
    "
    return
  fi

  sql_json "SELECT id, type, title, claim FROM entries WHERE status = 'active' ORDER BY title"
}

# ============================================================
# 2. Domain Query Commands
# ============================================================

domain_info() {
  local domain
  domain="$(esc "$1")"
  sql_json "
    PRAGMA foreign_keys = ON;
    SELECT
      dr.domain,
      dr.description,
      dr.status,
      dr.created_at,
      (SELECT COUNT(DISTINCT ed.entry_id)
       FROM entry_domains ed
       JOIN entries e ON e.id = ed.entry_id
       WHERE ed.domain = dr.domain AND e.status = 'active'
      ) AS active_entries,
      (SELECT group_concat(dp.pattern, ', ')
       FROM domain_paths dp
       WHERE dp.domain = dr.domain
      ) AS patterns
    FROM domain_registry dr
    WHERE dr.domain = '${domain}';
  "
}

resolve_directive_target() {
  local repo_root="$1"

  if [ -f "${repo_root}/CLAUDE.md" ] && grep -Fq "@AGENTS.md" "${repo_root}/CLAUDE.md"; then
    printf '%s\n' "${repo_root}/AGENTS.md"
    return
  fi

  if [ -f "${repo_root}/AGENTS.md" ]; then
    printf '%s\n' "${repo_root}/AGENTS.md"
    return
  fi

  printf '%s\n' "${repo_root}/CLAUDE.md"
}

domain_list() {
  local status_filter="${1:-active}"
  local ids_only="${2:-false}"

  if [ "$ids_only" = "true" ]; then
    if [ "$status_filter" = "all" ]; then
      sqlite3 "$VAULT" "
        SELECT COALESCE(json_group_array(domain), '[]')
        FROM (
          SELECT dr.domain
          FROM domain_registry dr
          ORDER BY dr.status, dr.domain
        );
      "
    else
      local esc_status
      esc_status="$(esc "$status_filter")"
      sqlite3 "$VAULT" "
        SELECT COALESCE(json_group_array(domain), '[]')
        FROM (
          SELECT dr.domain
          FROM domain_registry dr
          WHERE dr.status = '${esc_status}'
          ORDER BY dr.domain
        );
      "
    fi
    return
  fi

  if [ "$status_filter" = "all" ]; then
    sql_json "
      SELECT dr.domain, dr.description, dr.status,
        (SELECT COUNT(DISTINCT ed.entry_id)
         FROM entry_domains ed JOIN entries e ON e.id = ed.entry_id
         WHERE ed.domain = dr.domain AND e.status = 'active'
        ) AS active_entries
      FROM domain_registry dr
      ORDER BY dr.status, dr.domain;
    "
  else
    local esc_status
    esc_status="$(esc "$status_filter")"
    sql_json "
      SELECT dr.domain, dr.description, dr.status,
        (SELECT COUNT(DISTINCT ed.entry_id)
         FROM entry_domains ed JOIN entries e ON e.id = ed.entry_id
         WHERE ed.domain = dr.domain AND e.status = 'active'
        ) AS active_entries
      FROM domain_registry dr
      WHERE dr.status = '${esc_status}'
      ORDER BY dr.domain;
    "
  fi
}

domain_resolve_path() {
  local filepath
  filepath="$(esc "$1")"
  sql_json "
    WITH RECURSIVE prefixes(p, rest) AS (
      SELECT '', '${filepath}' || '/'
      UNION ALL
      SELECT p || substr(rest, 1, instr(rest, '/')),
             substr(rest, instr(rest, '/') + 1)
      FROM prefixes WHERE rest <> '' AND instr(rest, '/') > 0
    ), filepath_prefixes AS (
      SELECT p AS prefix FROM prefixes WHERE p <> ''
    )
    SELECT DISTINCT dp.domain, dr.description, dp.pattern AS matched_pattern
    FROM domain_paths dp
    JOIN domain_registry dr ON dr.domain = dp.domain
    JOIN filepath_prefixes fp ON fp.prefix = dp.pattern
    WHERE dr.status = 'active'
    UNION
    SELECT DISTINCT dp.domain, dr.description, dp.pattern AS matched_pattern
    FROM domain_paths dp
    JOIN domain_registry dr ON dr.domain = dp.domain
    WHERE dp.pattern = '*' AND dr.status = 'active'
    ORDER BY 1;
  "
}

# ============================================================
# 3. Domain Management Commands
# ============================================================

domain_add() {
  local domain description
  domain="$(esc "$1")"
  description="$(esc "$2")"
  sqlite3 "$VAULT" "
    PRAGMA foreign_keys = ON;
    INSERT INTO domain_registry(domain, description, status)
    VALUES ('${domain}', '${description}', 'active');
  "
  echo "Added domain: $1 (active)"
}

domain_merge() {
  local source target
  source="$(esc "$1")"
  target="$(esc "$2")"
  sqlite3 "$VAULT" "
    PRAGMA foreign_keys = ON;
    BEGIN;
    INSERT OR IGNORE INTO entry_domains(entry_id, domain)
    SELECT entry_id, '${target}' FROM entry_domains WHERE domain = '${source}';
    DELETE FROM entry_domains WHERE domain = '${source}';

    INSERT OR IGNORE INTO domain_paths(domain, pattern)
    SELECT '${target}', pattern FROM domain_paths WHERE domain = '${source}';
    DELETE FROM domain_paths WHERE domain = '${source}';

    UPDATE domain_registry SET status = 'deprecated' WHERE domain = '${source}';
    COMMIT;
  "
  echo "Merged: $1 -> $2"
}

domain_split() {
  local source new_a desc_a new_b desc_b
  source="$(esc "$1")"
  new_a="$(esc "$2")"
  desc_a="$(esc "$3")"
  new_b="$(esc "$4")"
  desc_b="$(esc "$5")"
  sqlite3 "$VAULT" "
    PRAGMA foreign_keys = ON;
    BEGIN;
    INSERT INTO domain_registry(domain, description, status)
    VALUES ('${new_a}', '${desc_a}', 'active'),
           ('${new_b}', '${desc_b}', 'active');

    INSERT OR IGNORE INTO entry_domains(entry_id, domain)
    SELECT ed.entry_id, '${new_a}' FROM entry_domains ed
    WHERE ed.domain = '${source}';
    INSERT OR IGNORE INTO entry_domains(entry_id, domain)
    SELECT ed.entry_id, '${new_b}' FROM entry_domains ed
    WHERE ed.domain = '${source}';

    DELETE FROM entry_domains WHERE domain = '${source}';

    DELETE FROM domain_paths WHERE domain = '${source}';

    UPDATE domain_registry SET status = 'deprecated' WHERE domain = '${source}';
    COMMIT;
  "
  echo "Split: $1 -> $2, $4"
  echo "Path patterns from '$1' have been removed. Set mappings for the new domains explicitly:"
  echo "  knowledge-gate domain-paths-set '$2' <patterns...>"
  echo "  knowledge-gate domain-paths-set '$4' <patterns...>"
}

domain_deprecate() {
  local domain merge_target
  domain="$(esc "$1")"
  merge_target="${2:-}"

  if [ -n "$merge_target" ]; then
    domain_merge "$1" "$merge_target"
    return
  fi

  local count
  count=$(sqlite3 "$VAULT" "
    SELECT COUNT(*) FROM entry_domains ed
    JOIN entries e ON e.id = ed.entry_id
    WHERE ed.domain = '${domain}' AND e.status = 'active';
  ")
  if [ "$count" -gt 0 ]; then
    echo "ERROR: Domain '$1' has $count active entries. Use --merge-into <target> to transfer entries first." >&2
    return 1
  fi

  sqlite3 "$VAULT" "
    PRAGMA foreign_keys = ON;
    UPDATE domain_registry SET status = 'deprecated' WHERE domain = '${domain}';
  "
  echo "Deprecated domain: $1"
}

validate_pattern() {
  local pattern="$1"
  if [ "$pattern" = "*" ]; then return 0; fi
  if [[ "$pattern" == */ ]]; then return 0; fi
  echo "ERROR: Invalid pattern '${pattern}'. Must end with '/' (directory prefix) or be '*' (global)." >&2
  return 1
}

domain_paths_set() {
  local raw_domain="$1"
  local domain sql
  domain="$(esc "$1")"
  shift
  sql="PRAGMA foreign_keys = ON; BEGIN; DELETE FROM domain_paths WHERE domain = '${domain}';"
  for pattern in "$@"; do
    validate_pattern "$pattern" || return 1
    local esc_pattern
    esc_pattern="$(esc "$pattern")"
    sql="${sql} INSERT INTO domain_paths(domain, pattern) VALUES ('${domain}', '${esc_pattern}');"
  done
  sql="${sql} COMMIT;"
  sqlite3 "$VAULT" "${sql}"
  echo "Set patterns for ${raw_domain}: $*"
}

domain_paths_add() {
  validate_pattern "$2" || return 1
  local domain pattern
  domain="$(esc "$1")"
  pattern="$(esc "$2")"
  sqlite3 "$VAULT" "
    PRAGMA foreign_keys = ON;
    INSERT INTO domain_paths(domain, pattern) VALUES ('${domain}', '${pattern}');
  "
  echo "Added pattern '$2' to domain '$1'"
}

domain_paths_remove() {
  local domain pattern
  domain="$(esc "$1")"
  pattern="$(esc "$2")"
  sqlite3 "$VAULT" "
    PRAGMA foreign_keys = ON;
    DELETE FROM domain_paths WHERE domain = '${domain}' AND pattern = '${pattern}';
  "
  echo "Removed pattern '$2' from domain '$1'"
}

# ============================================================
# 4. Knowledge Loading Commands
# ============================================================

add_entry() {
  local type="" title="" claim="" body="" alt="" considerations="" domains="" evidence=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --type) type="$2"; shift 2 ;;
      --title) title="$2"; shift 2 ;;
      --claim) claim="$2"; shift 2 ;;
      --body) body="$2"; shift 2 ;;
      --alternative) alt="$2"; shift 2 ;;
      --considerations) considerations="$2"; shift 2 ;;
      --domain) domains="$2"; shift 2 ;;
      --evidence) evidence="$2"; shift 2 ;;
      *) echo "Unknown option: $1" >&2; return 1 ;;
    esac
  done

  # Required field validation
  if [ -z "$type" ] || [ -z "$title" ] || [ -z "$claim" ] || [ -z "$body" ] || [ -z "$domains" ] || [ -z "$considerations" ]; then
    echo "ERROR: --type, --title, --claim, --body, --domain, and --considerations are required" >&2
    return 1
  fi

  # R3: anti-pattern requires alternative
  if [ "$type" = "anti-pattern" ] && [ -z "$alt" ]; then
    echo "ERROR: anti-pattern type requires --alternative" >&2
    return 1
  fi

  # R5: considerations must not be empty (trim whitespace before check)
  considerations="$(echo "$considerations" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
  if [ -z "$considerations" ]; then
    echo "ERROR: --considerations is required (use 'No special considerations' if none)" >&2
    return 1
  fi

  # Validate domains exist
  IFS=',' read -ra domain_check_arr <<< "$domains"
  for d in "${domain_check_arr[@]}"; do
    local trimmed_d
    trimmed_d="$(echo "$d" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    local exists
    exists=$(sqlite3 "$VAULT" "SELECT COUNT(*) FROM domain_registry WHERE domain='$(esc "$trimmed_d")' AND status='active';")
    if [ "$exists" -eq 0 ]; then
      echo "ERROR: Domain '${trimmed_d}' does not exist or is not active. Use 'domain-add' first." >&2
      return 1
    fi
  done

  # Generate kebab-case slug from title
  local id
  id="$(echo "$title" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9 ]//g' | tr ' ' '-' | sed 's/--*/-/g; s/^-//; s/-$//' | cut -c1-60)"

  # Slug collision resolution
  local base_id="$id" suffix=2
  while sqlite3 "$VAULT" "SELECT 1 FROM entries WHERE id='$(esc "$id")'" | grep -q 1; do
    id="${base_id}-${suffix}"
    suffix=$((suffix + 1))
  done

  # Evidence warning
  if [ -z "$evidence" ]; then
    echo "WARNING: --evidence not provided. Entry will lack traceability." >&2
  fi

  local esc_id esc_type esc_title esc_claim esc_body esc_alt esc_considerations
  esc_id="$(esc "$id")"
  esc_type="$(esc "$type")"
  esc_title="$(esc "$title")"
  esc_claim="$(esc "$claim")"
  esc_body="$(esc "$body")"
  esc_alt="$(esc "$alt")"
  esc_considerations="$(esc "$considerations")"

  local sql="PRAGMA foreign_keys = ON; BEGIN;
    INSERT INTO entries (id, type, title, claim, body, alternative, considerations)
    VALUES ('${esc_id}', '${esc_type}', '${esc_title}', '${esc_claim}', '${esc_body}',
            $([ -n "$alt" ] && echo "'${esc_alt}'" || echo "NULL"), '${esc_considerations}');"

  # entry_domains INSERT
  IFS=',' read -ra domain_arr <<< "$domains"
  for d in "${domain_arr[@]}"; do
    local esc_d
    esc_d="$(esc "$(echo "$d" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')")"
    sql="${sql} INSERT INTO entry_domains(entry_id, domain) VALUES ('${esc_id}', '${esc_d}');"
  done

  # evidence INSERT
  if [ -n "$evidence" ]; then
    IFS=',' read -ra ev_arr <<< "$evidence"
    for ev in "${ev_arr[@]}"; do
      ev="$(echo "$ev" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
      local ev_type ev_ref
      ev_type="$(esc "${ev%%:*}")"
      ev_ref="$(esc "${ev#*:}")"
      sql="${sql} INSERT INTO evidence(entry_id, type, ref) VALUES ('${esc_id}', '${ev_type}', '${ev_ref}');"
    done
  fi

  sql="${sql} COMMIT;"
  sqlite3 "$VAULT" "$sql"
  echo "$id"
}

pipeline_insert() {
  local json
  json=$(cat)

  local count
  count=$(echo "$json" | jq 'length')

  if [ "$count" -eq 0 ]; then
    echo "Inserted 0 entries"
    return 0
  fi

  local sql="PRAGMA foreign_keys = ON; BEGIN;"

  for ((i=0; i<count; i++)); do
    local item
    item=$(echo "$json" | jq ".[$i]")
    local raw_id id type title claim body alt considerations domains_json
    id=$(echo "$item" | jq -r '.id' | sed "s/'/''/g")
    raw_id="$id"
    type=$(echo "$item" | jq -r '.type' | sed "s/'/''/g")
    title=$(echo "$item" | jq -r '.title' | sed "s/'/''/g")
    claim=$(echo "$item" | jq -r '.claim' | sed "s/'/''/g")
    body=$(echo "$item" | jq -r '.body' | sed "s/'/''/g")
    alt=$(echo "$item" | jq -r '.alternative // empty' | sed "s/'/''/g")
    considerations=$(echo "$item" | jq -r '.considerations' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | sed "s/'/''/g")
    domains_json=$(echo "$item" | jq -c '.applies_to.domains // .domains // []')
    local ev_count
    ev_count=$(echo "$item" | jq '.evidence // [] | length')

    # Count domains early for validation
    local domain_count
    domain_count=$(echo "$domains_json" | jq 'length')

    # Required field validation
    if [ -z "$id" ] || [ "$id" = "null" ]; then
      echo "ERROR: entry at index $i has empty 'id'" >&2; return 1
    fi
    if [ -z "$type" ] || [ "$type" = "null" ]; then
      echo "ERROR: entry '${id}' has empty 'type'" >&2; return 1
    fi
    if [ "$type" != "fact" ] && [ "$type" != "anti-pattern" ]; then
      echo "ERROR: entry '${id}' has invalid type '${type}' (must be 'fact' or 'anti-pattern')" >&2; return 1
    fi
    if [ -z "$title" ] || [ "$title" = "null" ]; then
      echo "ERROR: entry '${id}' has empty 'title'" >&2; return 1
    fi
    if [ -z "$claim" ] || [ "$claim" = "null" ]; then
      echo "ERROR: entry '${id}' has empty 'claim'" >&2; return 1
    fi
    if [ -z "$body" ] || [ "$body" = "null" ]; then
      echo "ERROR: entry '${id}' has empty 'body'" >&2; return 1
    fi
    if [ "$domain_count" -eq 0 ]; then
      echo "ERROR: entry '${id}' has no domains" >&2; return 1
    fi
    if [ "$ev_count" -eq 0 ]; then
      echo "ERROR: entry '${id}' has no evidence" >&2; return 1
    fi

    # R3: anti-pattern requires alternative
    if [ "$type" = "anti-pattern" ] && [ -z "$alt" ]; then
      echo "ERROR: anti-pattern '${id}' requires alternative" >&2
      return 1
    fi

    # R5: considerations must not be empty
    if [ -z "$considerations" ]; then
      echo "ERROR: entry '${id}' has empty considerations" >&2
      return 1
    fi

    id="$(make_unique_entry_id "$raw_id")"
    reserve_id "$id"

    sql="${sql}
    INSERT INTO entries (id, type, status, title, claim, body, alternative, considerations, created_at, updated_at)
    VALUES ('${id}', '${type}', 'active', '${title}', '${claim}', '${body}',
            $([ -n "$alt" ] && echo "'${alt}'" || echo "NULL"), '${considerations}',
            datetime('now'), datetime('now'));"

    # domains — auto-create if missing, consume _proposed_domain if available
    for ((j=0; j<domain_count; j++)); do
      local domain
      domain=$(echo "$domains_json" | jq -r ".[$j]" | sed "s/'/''/g")

      # Check if this domain has a proposed definition in _proposed_domain
      local proposed_desc="auto-created by pipeline"
      local pd_match
      pd_match=$(echo "$item" | jq -c "._proposed_domain // [] | map(select(.name == \"$(echo "$domain" | sed 's/"/\\"/g')\")) | .[0] // empty")
      if [ -n "$pd_match" ]; then
        proposed_desc=$(echo "$pd_match" | jq -r '.description // "auto-created by pipeline"' | sed "s/'/''/g")
      fi

      sql="${sql}
      INSERT OR IGNORE INTO domain_registry(domain, description, status)
      VALUES ('${domain}', '${proposed_desc}', 'active');"

      # Insert suggested patterns from _proposed_domain if any
      if [ -n "$pd_match" ]; then
        local sp_count
        sp_count=$(echo "$pd_match" | jq '.suggested_patterns // [] | length')
        for ((k=0; k<sp_count; k++)); do
          local sp
          sp=$(echo "$pd_match" | jq -r ".suggested_patterns[$k]" | sed "s/'/''/g")
          validate_pattern "$sp" || return 1
          sql="${sql}
          INSERT OR IGNORE INTO domain_paths(domain, pattern) VALUES ('${domain}', '${sp}');"
        done
      fi

      sql="${sql}
      INSERT INTO entry_domains(entry_id, domain) VALUES ('${id}', '${domain}');"
    done

    # evidence
    for ((j=0; j<ev_count; j++)); do
      local ev_type ev_ref
      ev_type=$(echo "$item" | jq -r ".evidence[$j].type" | sed "s/'/''/g")
      ev_ref=$(echo "$item" | jq -r ".evidence[$j].ref" | sed "s/'/''/g")
      sql="${sql}
      INSERT INTO evidence(entry_id, type, ref) VALUES ('${id}', '${ev_type}', '${ev_ref}');"
    done

    # curation_queue
    local cq_count
    cq_count=$(echo "$item" | jq '.curation // [] | length')
    for ((j=0; j<cq_count; j++)); do
      local cq_related cq_reason cq_id
      cq_related=$(echo "$item" | jq -r ".curation[$j].related_id" | sed "s/'/''/g")
      cq_reason=$(echo "$item" | jq -r ".curation[$j].reason" | sed "s/'/''/g")
      cq_id="cq-${id}-$(date +%s)-${j}"
      sql="${sql}
      INSERT INTO curation_queue(id, type, entry_id, related_id, reason, status)
      VALUES ('${cq_id}', 'conflict', '${id}', '${cq_related}', '${cq_reason}', 'pending');"
    done
  done

  sql="${sql} COMMIT;"
  sqlite3 "$VAULT" "$sql"
  echo "Inserted ${count} entries"
}

pipeline_archive() {
  local entry_id="$1"
  local reason=""
  shift
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --reason) reason="$2"; shift 2 ;;
      *) echo "ERROR: Unknown option: $1" >&2; return 1 ;;
    esac
  done

  if [ -z "$entry_id" ]; then
    echo "ERROR: entry id is required" >&2; return 1
  fi
  if [ -z "$reason" ]; then
    echo "ERROR: --reason is required" >&2; return 1
  fi

  local current_status
  current_status=$(sqlite3 "$VAULT" "SELECT status FROM entries WHERE id='$(esc "$entry_id")';" 2>/dev/null || true)
  if [ -z "$current_status" ]; then
    echo "ERROR: Entry '${entry_id}' not found" >&2; return 1
  fi
  if [ "$current_status" = "archived" ]; then
    echo "ERROR: Entry '${entry_id}' is already archived" >&2; return 1
  fi

  local sql="UPDATE entries
    SET status='archived',
        archived_at=datetime('now'),
        archive_reason='$(esc "$reason")',
        updated_at=datetime('now')
    WHERE id='$(esc "$entry_id")' AND status='active';"

  sqlite3 "$VAULT" "$sql"
  echo "Archived ${entry_id}"
}

pipeline_update() {
  local entry_id="$1"
  local json
  json=$(cat)

  if [ -z "$entry_id" ]; then
    echo "ERROR: entry id is required" >&2; return 1
  fi
  if [ -z "$json" ]; then
    echo "ERROR: JSON input is required (via stdin)" >&2; return 1
  fi

  local current_status current_type
  current_status=$(sqlite3 "$VAULT" "SELECT status FROM entries WHERE id='$(esc "$entry_id")';" 2>/dev/null || true)
  if [ -z "$current_status" ]; then
    echo "ERROR: Entry '${entry_id}' not found" >&2; return 1
  fi
  if [ "$current_status" = "archived" ]; then
    echo "ERROR: Entry '${entry_id}' is archived — cannot update" >&2; return 1
  fi
  current_type=$(sqlite3 "$VAULT" "SELECT type FROM entries WHERE id='$(esc "$entry_id")';")

  # Build SET clause from JSON fields
  local set_parts=""
  local field value

  for field in title claim body alternative considerations; do
    if [ "$(echo "$json" | jq "has(\"${field}\")")" = "true" ]; then
      value=$(echo "$json" | jq -r ".${field} // empty")
      # R3: anti-pattern must keep alternative
      if [ "$field" = "alternative" ] && [ "$current_type" = "anti-pattern" ] && [ -z "$value" ]; then
        echo "ERROR: Cannot remove alternative from anti-pattern entry '${entry_id}'" >&2; return 1
      fi
      if [ -n "$value" ]; then
        set_parts="${set_parts:+${set_parts}, }${field}='$(esc "$value")'"
      fi
    fi
  done

  if [ -z "$set_parts" ] && [ "$(echo "$json" | jq 'has("domains")')" != "true" ]; then
    echo "ERROR: No fields to update" >&2; return 1
  fi

  local sql="BEGIN TRANSACTION;"

  if [ -n "$set_parts" ]; then
    sql="${sql} UPDATE entries SET ${set_parts}, updated_at=datetime('now') WHERE id='$(esc "$entry_id")';"
  else
    sql="${sql} UPDATE entries SET updated_at=datetime('now') WHERE id='$(esc "$entry_id")';"
  fi

  # Handle domain updates (full replace)
  if [ "$(echo "$json" | jq 'has("domains")')" = "true" ]; then
    local domain_count
    domain_count=$(echo "$json" | jq '.domains | length')
    if [ "$domain_count" -eq 0 ]; then
      echo "ERROR: domains array must not be empty" >&2; return 1
    fi

    sql="${sql} DELETE FROM entry_domains WHERE entry_id='$(esc "$entry_id")';"

    for ((i=0; i<domain_count; i++)); do
      local domain
      domain=$(echo "$json" | jq -r ".domains[$i]" | sed "s/'/''/g")
      # Verify domain exists
      local domain_exists
      domain_exists=$(sqlite3 "$VAULT" "SELECT COUNT(*) FROM domain_registry WHERE domain='${domain}' AND status='active';")
      if [ "$domain_exists" -eq 0 ]; then
        echo "ERROR: Domain '${domain}' does not exist or is not active" >&2; return 1
      fi
      sql="${sql} INSERT INTO entry_domains(entry_id, domain) VALUES ('$(esc "$entry_id")', '${domain}');"
    done
  fi

  sql="${sql} COMMIT;"
  sqlite3 "$VAULT" "$sql"
  echo "Updated ${entry_id}"
}

changeset_apply() {
  local changeset_file="$1"

  if [ ! -f "$changeset_file" ]; then
    echo "ERROR: Changeset file not found: ${changeset_file}" >&2
    return 1
  fi

  local version
  version=$(jq -r '.version // empty' "$changeset_file")
  if [ -z "$version" ] || [ "$version" != "1" ]; then
    echo "ERROR: Unsupported or missing changeset version (expected 1, got '${version}')" >&2
    return 1
  fi

  local accepted
  accepted=$(jq -c '[.entries[] | select(.status == "accepted") | .data]' "$changeset_file")

  local count
  count=$(echo "$accepted" | jq 'length')

  if [ "$count" -eq 0 ]; then
    echo "No accepted entries to apply"
    return 0
  fi

  # Idempotency: filter out entries whose ID already exists in vault.db
  local new_entries="[]"
  local skipped=0
  for ((i=0; i<count; i++)); do
    local entry_id
    entry_id=$(echo "$accepted" | jq -r ".[$i].id")
    local exists
    exists=$(sqlite3 "$VAULT" "SELECT COUNT(*) FROM entries WHERE id='$(echo "$entry_id" | sed "s/'/''/g")';" 2>/dev/null || echo "0")
    if [ "$exists" -gt 0 ]; then
      skipped=$((skipped + 1))
    else
      new_entries=$(echo "$new_entries" | jq --argjson entry "$(echo "$accepted" | jq ".[$i]")" '. + [$entry]')
    fi
  done

  local new_count
  new_count=$(echo "$new_entries" | jq 'length')

  if [ "$skipped" -gt 0 ]; then
    echo "Skipped ${skipped} entries already in vault"
  fi

  if [ "$new_count" -eq 0 ]; then
    echo "No new entries to apply (all ${count} already in vault)"
    return 0
  fi

  echo "$new_entries" | pipeline_insert
}

# ============================================================
# 5. Report + Utility Commands
# ============================================================

domain_report() {
  local active_count deprecated_count
  active_count=$(sqlite3 "$VAULT" "SELECT COUNT(*) FROM domain_registry WHERE status='active';")
  deprecated_count=$(sqlite3 "$VAULT" "SELECT COUNT(*) FROM domain_registry WHERE status='deprecated';")

  echo "=== Domain Registry (${active_count} active, ${deprecated_count} deprecated) ==="
  echo ""

  echo "  [!] SPLIT CANDIDATES (entries > 15):"
  local split
  split=$(sqlite3 "$VAULT" "
    SELECT
      dr.domain,
      sub.cnt,
      COALESCE((SELECT group_concat(dp.pattern, ', ')
                FROM domain_paths dp
                WHERE dp.domain = dr.domain), ''),
      COALESCE((SELECT group_concat(claim, ' || ')
                FROM (
                  SELECT e.claim
                  FROM entry_domains ed2
                  JOIN entries e ON e.id = ed2.entry_id
                  WHERE ed2.domain = dr.domain AND e.status = 'active'
                  ORDER BY e.updated_at DESC, e.created_at DESC, e.id
                  LIMIT 2
                )), '')
    FROM domain_registry dr
    JOIN (
      SELECT ed.domain, COUNT(DISTINCT ed.entry_id) AS cnt
      FROM entry_domains ed
      JOIN entries e ON e.id = ed.entry_id
      WHERE e.status = 'active'
      GROUP BY ed.domain
    ) sub ON sub.domain = dr.domain
    WHERE dr.status = 'active' AND sub.cnt > 15
    ORDER BY sub.cnt DESC;
  ")
  if [ -z "$split" ]; then
    echo "      (none)"
  else
    echo "$split" | while IFS='|' read -r domain cnt patterns top_claims; do
      echo "      ${domain} -- ${cnt} entries"
      if [ -n "$patterns" ]; then
        echo "        patterns: ${patterns}"
      fi
      if [ -n "$top_claims" ]; then
        echo "        sample claims:"
        printf '%s' "$top_claims" | awk -F' \\|\\| ' '{ for (i = 1; i <= NF; i++) printf "          - %s\n", $i }'
      fi
      echo "        suggest: knowledge-gate domain-split '${domain}' <new-a> <desc-a> <new-b> <desc-b>"
    done
  fi

  echo ""
  echo "  [!] MERGE CANDIDATES (entries <= 2):"
  local merge
  merge=$(sqlite3 "$VAULT" "
    SELECT
      dr.domain,
      COALESCE(sub.cnt, 0),
      COALESCE((SELECT group_concat(dp.pattern, ', ')
                FROM domain_paths dp
                WHERE dp.domain = dr.domain), ''),
      COALESCE((SELECT group_concat(claim, ' || ')
                FROM (
                  SELECT e.claim
                  FROM entry_domains ed2
                  JOIN entries e ON e.id = ed2.entry_id
                  WHERE ed2.domain = dr.domain AND e.status = 'active'
                  ORDER BY e.updated_at DESC, e.created_at DESC, e.id
                  LIMIT 2
                )), '')
    FROM domain_registry dr
    LEFT JOIN (
      SELECT ed.domain, COUNT(DISTINCT ed.entry_id) AS cnt
      FROM entry_domains ed
      JOIN entries e ON e.id = ed.entry_id
      WHERE e.status = 'active'
      GROUP BY ed.domain
    ) sub ON sub.domain = dr.domain
    WHERE dr.status = 'active' AND COALESCE(sub.cnt, 0) <= 2 AND COALESCE(sub.cnt, 0) > 0
    ORDER BY COALESCE(sub.cnt, 0);
  ")
  if [ -z "$merge" ]; then
    echo "      (none)"
  else
    echo "$merge" | while IFS='|' read -r domain cnt patterns top_claims; do
      echo "      ${domain} -- ${cnt} entries"
      if [ -n "$patterns" ]; then
        echo "        patterns: ${patterns}"
      fi
      if [ -n "$top_claims" ]; then
        echo "        sample claims:"
        printf '%s' "$top_claims" | awk -F' \\|\\| ' '{ for (i = 1; i <= NF; i++) printf "          - %s\n", $i }'
      fi
      echo "        suggest: consider merging '${domain}' into a neighboring domain"
    done
  fi

  echo ""
  echo "  [!] ORPHAN CANDIDATES (0 entries, 30+ days):"
  local orphans
  orphans=$(sqlite3 "$VAULT" "
    SELECT dr.domain, dr.created_at
    FROM domain_registry dr
    WHERE dr.status = 'active'
      AND (SELECT COUNT(*) FROM entry_domains ed JOIN entries e ON e.id=ed.entry_id
           WHERE ed.domain=dr.domain AND e.status='active') = 0
      AND julianday('now') - julianday(dr.created_at) > 30;
  ")
  if [ -z "$orphans" ]; then
    echo "      (none)"
  else
    echo "$orphans" | while IFS='|' read -r domain created; do
      echo "      ${domain} -- created ${created}, deprecated candidate"
    done
  fi

  echo ""
  echo "  [!] UNDERUTILIZED NEW DOMAINS (30+ days, entries <= 1):"
  local underutilized
  underutilized=$(sqlite3 "$VAULT" "
    SELECT dr.domain, COALESCE(sub.cnt, 0), dr.created_at
    FROM domain_registry dr
    LEFT JOIN (
      SELECT ed.domain, COUNT(DISTINCT ed.entry_id) AS cnt
      FROM entry_domains ed
      JOIN entries e ON e.id = ed.entry_id
      WHERE e.status = 'active'
      GROUP BY ed.domain
    ) sub ON sub.domain = dr.domain
    WHERE dr.status = 'active'
      AND COALESCE(sub.cnt, 0) <= 1
      AND julianday('now') - julianday(dr.created_at) > 30;
  ")
  if [ -z "$underutilized" ]; then
    echo "      (none)"
  else
    echo "$underutilized" | while IFS='|' read -r domain cnt created; do
      echo "      ${domain} -- ${cnt} entries, created ${created}"
    done
  fi

  echo ""
  echo "=== domain_paths Coverage ==="
  local total_patterns
  total_patterns=$(sqlite3 "$VAULT" "SELECT COUNT(*) FROM domain_paths;")
  echo "  Total patterns: ${total_patterns}"

  # Overly broad pattern check (requires git ls-files or find)
  if command -v git &>/dev/null && git rev-parse --is-inside-work-tree &>/dev/null 2>&1; then
    local total_files
    total_files=$(git ls-files 2>/dev/null | wc -l | tr -d ' ')
    if [ "$total_files" -gt 0 ]; then
      sqlite3 "$VAULT" "SELECT pattern FROM domain_paths WHERE pattern != '*';" | while IFS= read -r pattern; do
        local matched_files
        matched_files=$(git ls-files 2>/dev/null | grep -c "^${pattern}" || true)
        local pct=$((matched_files * 100 / total_files))
        if [ "$pct" -ge 30 ]; then
          echo "  Broadest pattern: ${pattern} (matches ${pct}% of repo)  [WARNING > 30%]"
        fi
      done
    fi
  fi

  # Structural mismatch: top-2 depth directories without domains
  if command -v git &>/dev/null && git rev-parse --is-inside-work-tree &>/dev/null 2>&1; then
    echo ""
    echo "  [!] STRUCTURAL MISMATCH (top directories without domain):"
    local top_dirs
    local mismatch_lines=""
    top_dirs=$(git ls-files 2>/dev/null | awk -F/ '
      NF >= 3 { print $1 "/" $2 "/" }
      NF == 2 { print $1 "/" }
    ' | sort | uniq -c | sort -rn | head -10 | awk '{print $2}' | head -5)
    if [ -n "$top_dirs" ]; then
      while IFS= read -r dir; do
        local has_domain
        has_domain=$(sqlite3 "$VAULT" "
          SELECT COUNT(*)
          FROM domain_paths
          WHERE pattern != '*'
            AND ('${dir}' LIKE pattern || '%' OR pattern LIKE '${dir}' || '%');
        ")
        if [ "$has_domain" -eq 0 ]; then
          mismatch_lines="${mismatch_lines}      ${dir} -- no domain mapping"$'\n'
          mismatch_lines="${mismatch_lines}        suggest: knowledge-gate domain-add '<domain>' 'Description' && knowledge-gate domain-paths-set '<domain>' '${dir}'"$'\n'
        fi
      done <<< "$top_dirs"
      if [ -n "$mismatch_lines" ]; then
        printf '%s' "$mismatch_lines"
      else
        echo "      (none)"
      fi
    else
      echo "      (none)"
    fi
  fi

  echo ""
  echo "=== Action Items ==="
  local action_count=0

  if [ -n "$split" ]; then
    while IFS='|' read -r domain _; do
      action_count=$((action_count + 1))
      echo "  ${action_count}. Split candidate: ${domain}"
    done <<< "$split"
  fi
  if [ -n "$merge" ]; then
    while IFS='|' read -r domain _; do
      action_count=$((action_count + 1))
      echo "  ${action_count}. Merge candidate: ${domain}"
    done <<< "$merge"
  fi
  if [ -n "$orphans" ]; then
    while IFS='|' read -r domain _; do
      action_count=$((action_count + 1))
      echo "  ${action_count}. Deprecate candidate: ${domain}"
    done <<< "$orphans"
  fi
  if [ "$action_count" -eq 0 ]; then
    echo "  No action items."
  fi
}

migrate_vault() {
  local current_version
  current_version=$(sqlite3 "$VAULT" "PRAGMA user_version;")
  local migration_dir="${PLUGIN_ROOT}/schema/migrations"

  if [ ! -d "$migration_dir" ]; then
    echo "No migrations directory found" >&2
    return 0
  fi

  local has_migrations=false
  local sql="BEGIN;"
  local migration_files=()
  while IFS= read -r f; do
    [ -n "$f" ] && migration_files+=("$f")
  done < <(list_migration_files "$migration_dir")

  for f in "${migration_files[@]}"; do
    local version
    version=$(basename "$f" .sql | grep -oE '^[0-9]+')
    if [ -n "$version" ] && [ "$((10#$version))" -gt "$current_version" ]; then
      has_migrations=true
      sql="${sql} $(cat "$f") PRAGMA user_version = $((10#$version));"
    fi
  done
  sql="${sql} COMMIT;"

  if [ "$has_migrations" = false ]; then
    echo "Already at version ${current_version}, no migrations to apply."
    return 0
  fi

  sqlite3 "$VAULT" "$sql"
  echo "Migrated from version ${current_version} to $(sqlite3 "$VAULT" "PRAGMA user_version;")"
}

curate_queue() {
  command -v jq &>/dev/null || { echo "ERROR: jq is required for curate" >&2; return 1; }

  local items
  items=$(sql_json "
    SELECT cq.id, cq.type, cq.entry_id, cq.related_id, cq.reason,
           e1.title AS entry_title, e1.claim AS entry_claim,
           e2.title AS related_title, e2.claim AS related_claim
    FROM curation_queue cq
    LEFT JOIN entries e1 ON e1.id = cq.entry_id
    LEFT JOIN entries e2 ON e2.id = cq.related_id
    WHERE cq.status = 'pending'
    ORDER BY cq.created_at;
  ")

  local count
  count=$(echo "$items" | jq 'length')
  if [ "$count" -eq 0 ]; then
    echo "No pending curation items."
    return 0
  fi

  echo "=== Curation Queue: ${count} pending items ==="
  echo "$items" | jq -c '.[]' | while IFS= read -r item; do
    local cq_id entry_id related_id reason entry_title related_title
    cq_id=$(echo "$item" | jq -r '.id')
    entry_id=$(echo "$item" | jq -r '.entry_id')
    related_id=$(echo "$item" | jq -r '.related_id')
    reason=$(echo "$item" | jq -r '.reason')
    entry_title=$(echo "$item" | jq -r '.entry_title')
    related_title=$(echo "$item" | jq -r '.related_title')

    echo ""
    echo "--- ${cq_id} ---"
    echo "Type: conflict"
    echo "Reason: ${reason}"
    echo "  [NEW]      ${entry_id}: ${entry_title}"
    echo "  [EXISTING] ${related_id}: ${related_title}"
    echo ""
    echo "Action? [keep-both / keep-existing / keep-new / archive-both / skip / quit]"
    read -r action

    case "$action" in
      keep-both)
        sqlite3 "$VAULT" "UPDATE curation_queue SET status='resolved', resolved_at=datetime('now') WHERE id='$(esc "$cq_id")';"
        echo "Resolved: both kept." ;;
      keep-existing)
        sqlite3 "$VAULT" "BEGIN; UPDATE entries SET status='archived', archived_at=datetime('now'), archive_reason='Replaced by existing entry: $(esc "$related_id")' WHERE id='$(esc "$entry_id")'; UPDATE curation_queue SET status='resolved', resolved_at=datetime('now') WHERE id='$(esc "$cq_id")'; COMMIT;"
        echo "Resolved: new entry archived." ;;
      keep-new)
        sqlite3 "$VAULT" "BEGIN; UPDATE entries SET status='archived', archived_at=datetime('now'), archive_reason='Replaced by newer entry: $(esc "$entry_id")' WHERE id='$(esc "$related_id")'; UPDATE curation_queue SET status='resolved', resolved_at=datetime('now') WHERE id='$(esc "$cq_id")'; COMMIT;"
        echo "Resolved: existing entry archived." ;;
      archive-both)
        sqlite3 "$VAULT" "BEGIN; UPDATE entries SET status='archived', archived_at=datetime('now'), archive_reason='Archived during curation review' WHERE id IN ('$(esc "$entry_id")','$(esc "$related_id")'); UPDATE curation_queue SET status='resolved', resolved_at=datetime('now') WHERE id='$(esc "$cq_id")'; COMMIT;"
        echo "Resolved: both archived." ;;
      skip) echo "Skipped." ;;
      quit) echo "Exiting curation."; return 0 ;;
      *) echo "Unknown action, skipping." ;;
    esac
  done
}

# ============================================================
# Auto-Migration
# ============================================================

auto_migrate() {
  local migration_dir="${PLUGIN_ROOT}/schema/migrations"
  [ -d "$migration_dir" ] || return 0

  local current_version
  current_version=$(sqlite3 "$VAULT" "PRAGMA user_version;")

  local sql="BEGIN;"
  local has_migrations=false
  local migration_files=()
  while IFS= read -r f; do
    [ -n "$f" ] && migration_files+=("$f")
  done < <(list_migration_files "$migration_dir")

  for f in "${migration_files[@]}"; do
    local version
    version=$(basename "$f" .sql | grep -oE '^[0-9]+')
    if [ -n "$version" ] && [ "$((10#$version))" -gt "$current_version" ]; then
      has_migrations=true
      sql="${sql} $(cat "$f") PRAGMA user_version = $((10#$version));"
    fi
  done
  sql="${sql} COMMIT;"

  if [ "$has_migrations" = true ]; then
    sqlite3 "$VAULT" "$sql"
  fi
}

# Run auto-migration for commands that access the vault
case "$CMD" in
  help|--help|-h|migrate|init-db) ;;  # skip auto-migration
  *) auto_migrate ;;
esac

case "$CMD" in
  # Knowledge Query Commands
  query-paths)
    ids_only="false"
    filepath=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --ids-only) ids_only="true"; shift ;;
        -*) echo "Usage: knowledge-gate query-paths [--ids-only] <filepath>" >&2; exit 1 ;;
        *) filepath="$1"; shift ;;
      esac
    done
    [ -n "$filepath" ] || { echo "Usage: knowledge-gate query-paths [--ids-only] <filepath>" >&2; exit 1; }
    query_by_path "$filepath" "$ids_only" ;;
  query-domain)
    ids_only="false"
    domain=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --ids-only) ids_only="true"; shift ;;
        -*) echo "Usage: knowledge-gate query-domain [--ids-only] <domain>" >&2; exit 1 ;;
        *) domain="$1"; shift ;;
      esac
    done
    [ -n "$domain" ] || { echo "Usage: knowledge-gate query-domain [--ids-only] <domain>" >&2; exit 1; }
    query_by_domain "$domain" "$ids_only" ;;
  search)
    ids_only="false"
    keyword=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --ids-only) ids_only="true"; shift ;;
        -*) echo "Usage: knowledge-gate search [--ids-only] <keyword>" >&2; exit 1 ;;
        *) keyword="$1"; shift ;;
      esac
    done
    [ -n "$keyword" ] || { echo "Usage: knowledge-gate search [--ids-only] <keyword>" >&2; exit 1; }
    search_entries "$keyword" "$ids_only" ;;
  get)
    [ $# -ge 1 ] || { echo "Usage: knowledge-gate get <id>" >&2; exit 1; }
    get_entry "$1" ;;
  get-many)
    [ $# -ge 1 ] || { echo "Usage: knowledge-gate get-many <id>..." >&2; exit 1; }
    get_entries "$@" ;;
  list)
    ids_only="false"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --ids-only) ids_only="true"; shift ;;
        *) echo "Usage: knowledge-gate list [--ids-only]" >&2; exit 1 ;;
      esac
    done
    list_entries "$ids_only" ;;

  # Domain Query Commands
  domain-info)
    [ $# -ge 1 ] || { echo "Usage: knowledge-gate domain-info <domain>" >&2; exit 1; }
    domain_info "$1" ;;
  domain-list)
    status_filter=""
    ids_only="false"
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --ids-only) ids_only="true"; shift ;;
        --status) status_filter="$2"; shift 2 ;;
        *) status_filter="$1"; shift ;;
      esac
    done
    domain_list "${status_filter:-active}" "$ids_only" ;;
  domain-resolve-path)
    [ $# -ge 1 ] || { echo "Usage: knowledge-gate domain-resolve-path <filepath>" >&2; exit 1; }
    domain_resolve_path "$1" ;;

  # Domain Management Commands
  domain-add)
    [ $# -ge 2 ] || { echo "Usage: knowledge-gate domain-add <domain> <description>" >&2; exit 1; }
    domain_add "$1" "$2" ;;
  domain-merge)
    [ $# -ge 2 ] || { echo "Usage: knowledge-gate domain-merge <source> <target>" >&2; exit 1; }
    domain_merge "$1" "$2" ;;
  domain-split)
    [ $# -ge 5 ] || { echo "Usage: knowledge-gate domain-split <source> <new-a> <desc-a> <new-b> <desc-b>" >&2; exit 1; }
    domain_split "$1" "$2" "$3" "$4" "$5" ;;
  domain-deprecate)
    [ $# -ge 1 ] || { echo "Usage: knowledge-gate domain-deprecate <domain> [--merge-into <target>]" >&2; exit 1; }
    merge_target=""
    domain="$1"; shift
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --merge-into) merge_target="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    domain_deprecate "$domain" "$merge_target" ;;
  domain-paths-set)
    [ $# -ge 2 ] || { echo "Usage: knowledge-gate domain-paths-set <domain> <pattern>..." >&2; exit 1; }
    domain="$1"; shift
    domain_paths_set "$domain" "$@" ;;
  domain-paths-add)
    [ $# -ge 2 ] || { echo "Usage: knowledge-gate domain-paths-add <domain> <pattern>" >&2; exit 1; }
    domain_paths_add "$1" "$2" ;;
  domain-paths-remove)
    [ $# -ge 2 ] || { echo "Usage: knowledge-gate domain-paths-remove <domain> <pattern>" >&2; exit 1; }
    domain_paths_remove "$1" "$2" ;;

  # Knowledge Loading Commands
  add)
    add_entry "$@" ;;
  _pipeline-insert)
    command -v jq &>/dev/null || { echo "ERROR: jq is required for _pipeline-insert" >&2; exit 1; }
    pipeline_insert ;;
  _pipeline-archive)
    [ $# -ge 1 ] || { echo "Usage: knowledge-gate _pipeline-archive <id> --reason '<reason>'" >&2; exit 1; }
    pipeline_archive "$@" ;;
  _pipeline-update)
    [ $# -ge 1 ] || { echo "Usage: knowledge-gate _pipeline-update <id> (reads JSON from stdin)" >&2; exit 1; }
    command -v jq &>/dev/null || { echo "ERROR: jq is required for _pipeline-update" >&2; exit 1; }
    pipeline_update "$@" ;;
  _changeset-apply)
    [ $# -ge 1 ] || { echo "Usage: knowledge-gate _changeset-apply <changeset-file>" >&2; exit 1; }
    command -v jq &>/dev/null || { echo "ERROR: jq is required for _changeset-apply" >&2; exit 1; }
    changeset_apply "$1" ;;
  init-db)
    init_db "${1:-}" ;;

  # Report + Utility Commands
  domain-report)
    domain_report ;;
  migrate)
    migrate_vault ;;
  curate)
    curate_queue ;;

  help|--help|-h)
    echo "knowledge-gate — Knowledge Vault CLI"
    echo ""
    echo "Usage: knowledge-gate <command> [arguments]"
    echo ""
    echo "Agent Runtime Commands:"
    echo "  query-paths [--ids-only] <filepath>  Query rules by file path (summary index by default)"
    echo "  query-domain [--ids-only] <domain>   Query rules by domain name (summary index by default)"
    echo "  search [--ids-only] <keyword>        FTS5 full-text keyword search (summary index by default)"
    echo "  get <id>                      Get full entry details (including body)"
    echo "  get-many <id>...              Get full details for multiple entries in one call"
    echo "  list [--ids-only]             List all active entries (summary index by default)"
    echo ""
    echo "Domain Queries:"
    echo "  domain-info <domain>          Domain details (description, patterns, entry count)"
    echo "  domain-list [--status X] [--ids-only]  List domains or emit a lightweight domain ID index"
    echo "  domain-resolve-path <filepath> Reverse-lookup file path to domains"
    echo ""
    echo "Domain Management:"
    echo "  domain-add <domain> <desc>    Register new domain"
    echo "  domain-merge <src> <target>   Merge domains (transfers entries + paths)"
    echo "  domain-split <src> <a> <da> <b> <db>  Split domain into two"
    echo "  domain-deprecate <domain> [--merge-into <target>]"
    echo "  domain-paths-set <domain> <pattern>..."
    echo "  domain-paths-add <domain> <pattern>"
    echo "  domain-paths-remove <domain> <pattern>"
    echo ""
    echo "Knowledge Loading:"
    echo "  add --type <fact|anti-pattern> --title <t> --claim <c> --body <b>"
    echo "      --domain <d>[,<d>...] [--alternative <alt>] --considerations <text>"
    echo "      [--evidence <type:ref>[,<type:ref>...]]"
    echo "  _pipeline-insert              Bulk insert from JSON stdin (pipeline only)"
    echo "  _pipeline-archive <id>        Archive an entry with reason (pipeline only)"
    echo "  _pipeline-update <id>         Update entry fields from JSON stdin (pipeline only)"
    echo ""
    echo "Diagnostics & Maintenance:"
    echo "  init-db [path]                Create a new vault from bundled schema"
    echo "  domain-report                 Domain health diagnosis + adjustment candidates"
    echo "  migrate                       Apply PRAGMA user_version schema migrations"
    echo "  curate                        Interactive curation queue resolution"
    echo ""
    echo "Environment:"
    echo "  KNOWLEDGE_VAULT_PATH          Vault location (default: .knowledge/vault.db relative to CLI)"
    echo ""
    echo "Examples:"
    echo "  knowledge-gate query-paths src/api/auth/login.ts"
    echo "  knowledge-gate domain-resolve-path src/services/payment.rb"
    echo "  knowledge-gate search \"callback\""
    echo "  knowledge-gate domain-report"
    ;;

  *)
    echo "Unknown command: $CMD" >&2
    echo "Run 'knowledge-gate help' for usage." >&2
    exit 1 ;;
esac
